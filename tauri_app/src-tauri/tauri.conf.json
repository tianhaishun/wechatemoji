{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WeChat Emoji to Feishu",
  "version": "0.1.0",
  "identifier": "com.justin.wechatemoji.tauri",
  "build": {
    "frontendDist": "../../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WeChat Emoji -> Feishu",
        "width": 1040,
        "height": 920,
        "minWidth": 860,
        "minHeight": 720,
        "resizable": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://www.feishu.cn https://*.feishu.cn https://*.feishucdn.com;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
